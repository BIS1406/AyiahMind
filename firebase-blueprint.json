{
  "entities": {
    "users": {
      "title": "User",
      "description": "User profile with basic information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "studyStreak": { "type": "integer" },
        "quizAverage": { "type": "number" }
      },
      "required": ["uid", "email"]
    },
    "tasks": {
      "title": "Task",
      "description": "A study task or assignment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "completed": { "type": "boolean" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] }
      },
      "required": ["userId", "title"]
    },
    "uploads": {
      "title": "Upload",
      "description": "A user-uploaded study document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "fileName": { "type": "string" },
        "fileType": { "type": "string" },
        "uploadDate": { "type": "string", "format": "date-time" },
        "aiSummary": { "type": "string" },
        "structuredSummary": { "type": "object" },
        "confidenceScore": { "type": "number" },
        "userFeedback": {
          "type": "object",
          "properties": {
            "rating": { "type": "string", "enum": ["positive", "negative"] },
            "comment": { "type": "string" },
            "timestamp": { "type": "string", "format": "date-time" }
          }
        }
      },
      "required": ["userId", "fileName"]
    },
    "quizzes": {
      "title": "Quiz",
      "description": "A generated quiz based on material",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "uploadId": { "type": "string" },
        "questions": { "type": "array" },
        "score": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "chats": {
      "title": "Chat",
      "description": "A chat session with Dior",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "messages": {
      "title": "Message",
      "description": "An individual message",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "planner_events": {
      "title": "Study Event",
      "description": "A scheduled study session in the timetable",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "dayOfWeek": { "type": "integer", "description": "0-6 for Sun-Sat" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" }
      },
      "required": ["title", "dayOfWeek", "startTime", "endTime"]
    },
    "planner_goals": {
      "title": "Daily Goal",
      "description": "Daily study targets",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "completed": { "type": "boolean" },
        "date": { "type": "string", "format": "date" }
      },
      "required": ["text", "date"]
    },
    "planner_exams": {
      "title": "Exam",
      "description": "Upcoming exams for countdown",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "subject": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["subject", "date"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "users",
      "description": "Collection of user profiles"
    },
    "users/{userId}/tasks/{taskId}": {
      "schema": "tasks",
      "description": "User's study tasks"
    },
    "users/{userId}/uploads/{uploadId}": {
      "schema": "uploads",
      "description": "User's uploaded study materials"
    },
    "users/{userId}/quizzes/{quizId}": {
      "schema": "quizzes",
      "description": "Quizzes generated for the user"
    },
    "users/{userId}/chats/{chatId}": {
      "schema": "chats",
      "description": "Chat sessions with the AI Study Coach"
    },
    "users/{userId}/chats/{chatId}/messages/{messageId}": {
      "schema": "messages",
      "description": "Individual messages in a chat session"
    },
    "users/{userId}/planner_events/{eventId}": {
      "schema": "planner_events",
      "description": "User's scheduled study sessions"
    },
    "users/{userId}/planner_goals/{goalId}": {
      "schema": "planner_goals",
      "description": "User's daily study goals"
    },
    "users/{userId}/planner_exams/{examId}": {
      "schema": "planner_exams",
      "description": "User's upcoming exams"
    }
  }
}
