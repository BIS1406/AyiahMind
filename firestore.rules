rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'google.com');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation Helpers
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'photoURL', 'tier', 'studyStreak', 'quizAverage', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 9 &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             (data.displayName == null || (data.displayName is string && data.displayName.size() <= 128)) &&
             (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1024)) &&
             data.tier in ['free', 'premium'] &&
             data.studyStreak is int &&
             (data.quizAverage is number || data.quizAverage is int) &&
             data.createdAt is string &&
             data.updatedAt is string;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['userId', 'title', 'completed', 'priority', 'dueDate', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 7 &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 200 &&
             data.completed is bool &&
             data.priority in ['low', 'medium', 'high'] &&
             data.dueDate is string &&
             data.createdAt is string &&
             data.updatedAt is string;
    }

    function isValidUpload(data) {
      return data.keys().hasAll(['userId', 'fileName', 'fileType', 'fileSize', 'uploadDate', 'aiSummary', 'concepts', 'questions', 'strategy', 'processed', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 12 &&
             data.userId == request.auth.uid &&
             data.fileName is string && data.fileName.size() <= 256 &&
             data.processed is bool;
    }

    function isValidGoal(data) {
      return data.keys().hasAll(['text', 'completed', 'date', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 5 &&
             data.text is string && data.text.size() <= 500 &&
             data.completed is bool;
    }

    function isValidExam(data) {
      return data.keys().hasAll(['subject', 'date', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 4 &&
             data.subject is string && data.subject.size() <= 200 &&
             data.date is string;
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['title', 'dayOfWeek', 'startTime', 'endTime', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 6 &&
             data.title is string &&
             data.dayOfWeek is int &&
             data.startTime is string &&
             data.endTime is string;
    }

    // Root Collections
    match /users/{userId} {
      // PII isolation: only owner can read their own profile
      allow get: if isOwner(userId);
      
      // Allow creation for signed-in users (verification can be pending for email/password)
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(request.resource.data);
      
      // Verification required for updates
      allow update: if isVerified() && isOwner(userId) && 
                      isValidId(userId) &&
                      isValidUser(request.resource.data) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt', 'studyStreak', 'quizAverage', 'tier']);

      match /tasks/{taskId} {
        allow list, get: if isOwner(userId);
        allow create: if isVerified() && isOwner(userId) && isValidId(taskId) && isValidTask(request.resource.data);
        allow update: if isVerified() && isOwner(userId) && isValidId(taskId) && isValidTask(request.resource.data) &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['completed', 'updatedAt', 'title', 'dueDate', 'priority']);
        allow delete: if isVerified() && isOwner(userId) && isValidId(taskId);
      }

      match /uploads/{uploadId} {
        allow list, get: if isOwner(userId);
        allow create: if isVerified() && isOwner(userId) && isValidId(uploadId) && isValidUpload(request.resource.data);
        allow update: if isVerified() && isOwner(userId) && isValidId(uploadId) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasAny(['structuredSummary', 'userFeedback', 'updatedAt']);
        allow delete: if isVerified() && isOwner(userId) && isValidId(uploadId);
      }

      match /quizzes/{quizId} {
        allow list, get: if isOwner(userId);
        allow create, update: if isVerified() && isOwner(userId) && isValidId(quizId);
        allow delete: if isVerified() && isOwner(userId) && isValidId(quizId);
      }

      match /chats/{chatId} {
        allow list, get: if isOwner(userId);
        allow create, update, delete: if isVerified() && isOwner(userId) && isValidId(chatId);

        match /messages/{messageId} {
          allow list, get: if isOwner(userId);
          allow create: if isVerified() && isOwner(userId) && isValidId(messageId);
        }
      }

      match /planner_events/{eventId} {
        allow list, get: if isOwner(userId);
        allow create: if isVerified() && isOwner(userId) && isValidId(eventId) && isValidEvent(request.resource.data);
        allow update: if isVerified() && isOwner(userId) && isValidId(eventId) && isValidEvent(request.resource.data);
        allow delete: if isVerified() && isOwner(userId) && isValidId(eventId);
      }

      match /planner_goals/{goalId} {
        allow list, get: if isOwner(userId);
        allow create: if isVerified() && isOwner(userId) && isValidId(goalId) && isValidGoal(request.resource.data);
        allow update: if isVerified() && isOwner(userId) && isValidId(goalId) && isValidGoal(request.resource.data);
        allow delete: if isVerified() && isOwner(userId) && isValidId(goalId);
      }

      match /planner_exams/{examId} {
        allow list, get: if isOwner(userId);
        allow create: if isVerified() && isOwner(userId) && isValidId(examId) && isValidExam(request.resource.data);
        allow update: if isVerified() && isOwner(userId) && isValidId(examId) && isValidExam(request.resource.data);
        allow delete: if isVerified() && isOwner(userId) && isValidId(examId);
      }
    }
  }
}
